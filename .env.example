# Database
DATABASE_URL=postgresql://swotta:swotta_dev@localhost:5432/swotta_dev
DATABASE_TEST_URL=postgresql://swotta:swotta_test@localhost:5433/swotta_test

# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (browser-side)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Voyage AI
VOYAGE_API_KEY=pa-xxx

# Google Cloud Storage
GCS_BUCKET_NAME=swotta-uploads
GCS_PROJECT_ID=swotta

# Resend
RESEND_API_KEY=re_xxx

# Inngest
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx
