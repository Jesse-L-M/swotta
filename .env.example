# Database
DATABASE_URL=postgresql://swotta:swotta_dev@localhost:5432/swotta_dev
DATABASE_TEST_URL=postgresql://swotta:swotta_test@localhost:5433/swotta_test

# Firebase Admin SDK (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"

# Firebase Client SDK (browser-side; also required during CI/CD builds)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Voyage AI
VOYAGE_API_KEY=your-voyage-api-key

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket
GCS_PROJECT_ID=your-gcp-project-id

# Resend
RESEND_API_KEY=your-resend-api-key

# Session security (optional in local dev, required in production flows)
DIAGNOSTIC_SESSION_SECRET=your-diagnostic-session-secret
SESSION_SHARE_SECRET=your-session-share-secret

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
